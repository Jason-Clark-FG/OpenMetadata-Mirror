{
    "$id": "https://open-metadata.org/schema/entity/services/connections/database/ssasConnection.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "SSASConnection",
    "description": "SSAS Metadata Database Connection Config",
    "type": "object",
    "javaType": "org.openmetadata.schema.services.connections.database.SSASConnection",
    "definitions": {
      "SSASType": {
        "description": "Service type.",
        "type": "string",
        "enum": ["SSAS"],
        "default": "SSAS"
      },
      "basicAuth": {
        "title": "Basic Authentication",
        "description": "Authenticate using username and password.",
        "type": "object",
        "properties": {
          "authType": {
            "title": "Auth Type",
            "description": "Authentication type.",
            "type": "string",
            "enum": ["basic"],
            "default": "basic"
          },
          "username": {
            "title": "Username",
            "description": "Username for SSAS authentication.",
            "type": "string"
          },
          "password": {
            "title": "Password",
            "description": "Password for SSAS authentication.",
            "type": "string",
            "format": "password"
          }
        },
        "required": ["username", "password"],
        "additionalProperties": false
      },
      "azureServicePrincipalAuth": {
        "title": "Azure Service Principal Authentication",
        "description": "Authenticate to Azure Analysis Services using a Service Principal.",
        "type": "object",
        "properties": {
          "authType": {
            "title": "Auth Type",
            "description": "Authentication type.",
            "type": "string",
            "enum": ["azureServicePrincipal"],
            "default": "azureServicePrincipal"
          },
          "clientId": {
            "title": "Client ID",
            "description": "Azure Active Directory App client ID (Service Principal).",
            "type": "string"
          },
          "clientSecret": {
            "title": "Client Secret",
            "description": "Azure Active Directory App client secret (Service Principal).",
            "type": "string",
            "format": "password"
          },
          "tenantId": {
            "title": "Tenant ID",
            "description": "Azure Active Directory Tenant ID.",
            "type": "string"
          },
          "authorityURI": {
            "title": "Authority URI",
            "description": "Authority URI for Azure AD authentication.",
            "type": "string",
            "default": "https://login.microsoftonline.com/"
          }
        },
        "required": ["clientId", "clientSecret", "tenantId"],
        "additionalProperties": false
      }
    },
    "properties": {
      "type": {
        "title": "Service Type",
        "description": "Service Type",
        "$ref": "#/definitions/SSASType",
        "default": "SSAS"
      },
      "httpConnection": {
        "title": "HTTP Link for SSAS/AAS Access",
        "description": "XMLA endpoint URL for on-premises SSAS (e.g. http://server/olap/msmdpump.dll) or Azure Analysis Services server URL (e.g. asazure://eastus.asazure.windows.net/myserver).",
        "type": "string"
      },
      "authConfig": {
        "title": "Authentication Configuration",
        "description": "Authentication configuration for SSAS or Azure Analysis Services.",
        "oneOf": [
          {
            "$ref": "#/definitions/basicAuth"
          },
          {
            "$ref": "#/definitions/azureServicePrincipalAuth"
          }
        ]
      },
      "supportsMetadataExtraction": {
        "title": "Supports Metadata Extraction",
        "$ref": "../connectionBasicType.json#/definitions/supportsMetadataExtraction"
      },
      "supportsLineageExtraction": {
        "title": "Supports Lineage Extraction",
        "$ref": "../connectionBasicType.json#/definitions/supportsLineageExtraction"
      }
    },
    "additionalProperties": false,
    "required": ["httpConnection", "authConfig"]
  }
