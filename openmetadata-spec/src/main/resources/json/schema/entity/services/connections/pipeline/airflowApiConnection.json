{
  "$id": "https://open-metadata.org/schema/entity/services/connections/pipeline/airflowApiConnection.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AirflowApiConnection",
  "description": "Airflow REST API Connection Config",
  "type": "object",
  "javaType": "org.openmetadata.schema.services.connections.pipeline.AirflowApiConnection",
  "definitions": {
    "AirflowApiType": {
      "description": "Service type.",
      "type": "string",
      "enum": ["AirflowApi"],
      "default": "AirflowApi"
    },
    "ApiVersion": {
      "description": "Airflow REST API version. Use v1 for Airflow 2.x and v2 for Airflow 3.x. Auto will detect the version automatically.",
      "type": "string",
      "enum": ["v1", "v2", "auto"],
      "default": "auto"
    }
  },
  "properties": {
    "type": {
      "title": "Service Type",
      "description": "Service Type",
      "$ref": "#/definitions/AirflowApiType",
      "default": "AirflowApi"
    },
    "hostPort": {
      "title": "Host And Port",
      "description": "URL to the Airflow REST API. E.g., http://localhost:8080",
      "type": "string",
      "format": "uri"
    },
    "username": {
      "title": "Username",
      "description": "Username for basic authentication to the Airflow API.",
      "type": "string"
    },
    "password": {
      "title": "Password",
      "description": "Password for basic authentication to the Airflow API.",
      "type": "string",
      "format": "password"
    },
    "token": {
      "title": "Token",
      "description": "Bearer token for API authentication.",
      "type": "string",
      "format": "password"
    },
    "apiVersion": {
      "title": "API Version",
      "description": "Airflow REST API version.",
      "$ref": "#/definitions/ApiVersion",
      "default": "auto"
    },
    "numberOfStatus": {
      "title": "Number Of Status",
      "description": "Number of past DAG runs to fetch for status history.",
      "type": "integer",
      "default": 10
    },
    "verifySSL": {
      "title": "Verify SSL",
      "description": "Whether to verify SSL certificates when connecting to the Airflow API.",
      "type": "boolean",
      "default": true
    },
    "pipelineFilterPattern": {
      "description": "Regex exclude pipelines.",
      "$ref": "../../../../type/filterPattern.json#/definitions/filterPattern",
      "title": "Default Pipeline Filter Pattern"
    },
    "supportsMetadataExtraction": {
      "title": "Supports Metadata Extraction",
      "$ref": "../connectionBasicType.json#/definitions/supportsMetadataExtraction"
    }
  },
  "additionalProperties": false,
  "required": ["hostPort"]
}
