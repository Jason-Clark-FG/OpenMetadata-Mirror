{
  "source": {
    "index": ["di-data-assets-*"]
  },
  "dest": {
    "index": "di-rollup-daily"
  },
  "pivot": {
    "group_by": {
      "date": {
        "date_histogram": {
          "field": "@timestamp",
          "calendar_interval": "1d"
        }
      },
      "entityType": {
        "terms": { "field": "entityType.keyword" }
      },
      "tier": {
        "terms": { "field": "tier.tagFQN" }
      },
      "team": {
        "terms": { "field": "team" }
      },
      "hasOwner": {
        "terms": { "field": "hasOwner" }
      },
      "hasDescription": {
        "terms": { "field": "hasDescription" }
      }
    },
    "aggregations": {
      "entity_count": {
        "value_count": { "field": "id.keyword" }
      },
      "total_columns": {
        "sum": { "field": "numberOfColumns" }
      },
      "described_columns": {
        "sum": { "field": "numberOfColumnsWithDescription" }
      },
      "unique_owners": {
        "cardinality": { "field": "owners.id.keyword" }
      }
    }
  },
  "frequency": "1h",
  "sync": {
    "time": {
      "field": "@timestamp",
      "delay": "60s"
    }
  }
}
