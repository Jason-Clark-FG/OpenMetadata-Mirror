{
  "template": {
    "settings": {
      "index": {
        "max_ngram_diff": 17
      }
    },
    "mappings": {
      "properties": {
        "@timestamp": { "type": "date" },
        "id": {
          "type": "text",
          "fields": {
            "keyword": {
              "type": "keyword",
              "ignore_above": 256
            }
          }
        },
        "hasDescription": { "type": "integer" },
        "hasOwner": { "type": "integer" },
        "team": { "type": "keyword" },
        "numberOfColumns": { "type": "integer" },
        "numberOfColumnsWithDescription": { "type": "integer" },
        "hasColumnDescription": { "type": "integer" }
      }
    }
  }
}
