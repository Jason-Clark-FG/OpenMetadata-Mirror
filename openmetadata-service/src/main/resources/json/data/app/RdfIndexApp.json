{
  "name": "RdfIndexApp",
  "displayName": "RDF Knowledge Graph Indexing",
  "allowConfiguration": true,
  "appConfiguration": {
    "entities": [],
    "recreateIndex": false,
    "batchSize": 100,
    "producerThreads": 2,
    "consumerThreads": 3,
    "queueSize": 5000,
    "useDistributedIndexing": true,
    "partitionSize": 10000
  },
  "appSchedule": {
    "scheduleTimeline": "Custom",
    "cronExpression": "0 0 * * *"
  },
  "supportsInterrupt": true
}
